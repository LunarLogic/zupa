<%
  is_new = trip.nil? || trip.new_record?
  form_url = is_new ? main_app.admin_area_trips_wizard_index_path : main_app.basic_admin_area_trips_wizard_path(trip)
  form_method = is_new ? :post : :patch
  default_date = Date.current + ((4 - Date.current.wday) % 7 == 0 ? 7 : (4 - Date.current.wday) % 7)
  current_date = trip&.date || default_date
  current_admin_user_id = trip&.admin_user_id
%>

<div class="wizard__step wizard__step--basic">
  <h3><%= t("admin.trips_wizard.steps.basic.title") %></h3>

  <%= form_with url: form_url,
    method: form_method,
    data: {turbo: "true", turbo_stream: "true"},
    local: false,
    class: "wizard__form" do |f| %>
    <div class="form-group">
      <label for="trip_date"><%= t("admin.trips_wizard.steps.basic.date") %></label>
      <input type="date" id="trip_date" name="date" value="<%= current_date&.iso8601 %>" class="form-control" />
    </div>

    <div class="form-group">
      <label for="trip_admin_user_id"><%= t("admin.trips_wizard.steps.basic.organiser") %></label>
      <select id="trip_admin_user_id" name="admin_user_id" class="form-control">
        <% AdminUser.order(:last_name).each do |u| %>
          <option value="<%= u.id %>" <%= "selected" if u.id == current_admin_user_id %>>
            <%= u.full_name %>
          </option>
        <% end %>
      </select>
    </div>

    <div class="wizard__actions">
      <button type="submit" class="btn btn-primary"
        data-turbo-submits-with="Zapisuję...">
        <%= t("admin.trips_wizard.steps.basic.continue") %> →
      </button>
    </div>
  <% end %>
</div>
