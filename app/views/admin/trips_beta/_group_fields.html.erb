<div class="trip-beta-group" data-trip-form-target="group" style="position:relative; border:1px solid #ddd; padding:1rem; margin-bottom:1rem;">
  <%= f.hidden_field :id if f.object.persisted? %>
  <%= f.hidden_field :_destroy, data: {trip_form_target: "groupDestroy"}, value: "0" %>

  <button type="button" class="btn btn-sm btn-danger"
    data-action="trip-form#removeGroup"
    style="position:absolute; top:0.5rem; right:0.5rem; padding:0.1rem 0.5rem; line-height:1;">
    ✕
  </button>

  <h4 style="margin-top:0;"><%= I18n.t("admin.trips_beta.form.group", default: "Grupa") %></h4>

  <div class="form-group">
    <label><%= I18n.t("admin.trips_beta.form.volunteers", default: "Wolontariusze") %></label>
    <%= f.collection_select :volunteer_ids, volunteers_pool, :id, :full_name,
      {include_blank: false},
      {multiple: true, size: [volunteers_pool.size, 6].min, class: "form-control", wrapper: false} %>
  </div>

  <div class="form-group">
    <label><%= I18n.t("admin.trips_beta.form.drivers", default: "Kierowcy") %></label>
    <%= f.collection_select :driver_ids, volunteers_pool, :id, :full_name,
      {include_blank: false},
      {multiple: true, size: [volunteers_pool.size, 6].min, class: "form-control", wrapper: false} %>
  </div>

  <%
    selected_location_ids = f.object.trip_destinations.reject(&:marked_for_destruction?).map(&:location_id).compact
  %>
  <div class="form-group">
    <label><%= I18n.t("admin.trips_beta.form.locations", default: "Lokacje") %></label>
    <select multiple class="form-control"
      size="<%= [active_locations.size, 6].min %>"
      data-trip-form-target="locationSelect"
      data-action="change->trip-form#syncDestinations">
      <% active_locations.each do |loc| %>
        <option value="<%= loc.id %>" <%= "selected" if selected_location_ids.include?(loc.id) %>><%= loc.name %></option>
      <% end %>
    </select>
  </div>

  <h5><%= I18n.t("admin.trips_beta.form.destinations", default: "Destynacje") %></h5>

  <div class="trip-beta-destinations" data-trip-form-target="destinationsContainer">
    <%= f.fields_for :trip_destinations do |dest_form| %>
      <%= render "destination_fields", f: dest_form, active_locations: active_locations %>
    <% end %>
  </div>
</div>
