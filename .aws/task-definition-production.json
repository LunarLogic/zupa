{
  "containerDefinitions": [
    {
      "name": "app",
      "image": "{{ECR_REGISTRY}}/{{APP_NAME}}:latest",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "RAILS_ENV",
          "value": "production"
        }
      ],
      "mountPoints": [],
      "volumesFrom": [],
      "secrets": [
        {
          "name": "HOST",
          "valueFrom": "{{SECRETS_ARN}}:HOST::"
        },
        {
          "name": "REACT_API_BASE_URL",
          "valueFrom": "{{SECRETS_ARN}}:REACT_API_BASE_URL::"
        },
        {
          "name": "REACT_APP_GOOGLE_MAPS_API_KEY",
          "valueFrom": "{{SECRETS_ARN}}:REACT_APP_GOOGLE_MAPS_API_KEY::"
        },
        {
          "name": "REACT_GTM_ID",
          "valueFrom": "{{SECRETS_ARN}}:REACT_GTM_ID::"
        },
        {
          "name": "REACT_APP_USE_GOOGLE_MAPS_API",
          "valueFrom": "{{SECRETS_ARN}}:REACT_APP_USE_GOOGLE_MAPS_API::"
        },
        {
          "name": "DATABASE_URL",
          "valueFrom": "{{SECRETS_ARN}}:DATABASE_URL::"
        },
        {
          "name": "SECRET_KEY_BASE",
          "valueFrom": "{{SECRETS_ARN}}:SECRET_KEY_BASE::"
        },
        {
          "name": "GOOGLE_DRIVE_PRIVATE_KEY_ID",
          "valueFrom": "{{SECRETS_ARN}}:GOOGLE_DRIVE_PRIVATE_KEY_ID::"
        },
        {
          "name": "GOOGLE_DRIVE_PRIVATE_KEY",
          "valueFrom": "{{SECRETS_ARN}}:GOOGLE_DRIVE_PRIVATE_KEY::"
        },
        {
          "name": "GOOGLE_DRIVE_CLIENT_EMAIL",
          "valueFrom": "{{SECRETS_ARN}}:GOOGLE_DRIVE_CLIENT_EMAIL::"
        },
        {
          "name": "GOOGLE_DRIVE_CLIENT_ID",
          "valueFrom": "{{SECRETS_ARN}}:GOOGLE_DRIVE_CLIENT_ID::"
        },
        {
          "name": "GOOGLE_DRIVE_CLIENT_CERT_URL",
          "valueFrom": "{{SECRETS_ARN}}:GOOGLE_DRIVE_CLIENT_CERT_URL::"
        },
        {
          "name": "GOOGLE_DRIVE_PROJECT_ID",
          "valueFrom": "{{SECRETS_ARN}}:GOOGLE_DRIVE_PROJECT_ID::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "{{AWS_LOG_GROUP}}",
          "awslogs-region": "{{AWS_REGION}}",
          "awslogs-stream-prefix": "{{APP_NAME}}"
        }
      }
    }
  ],
  "family": "{{APP_NAME}}__production",
  "executionRoleArn": "{{EXECUTION_ROLE_ARN}}",
  "taskRoleArn": "{{TASK_ROLE_ARN}}",
  "networkMode": "awsvpc",
  "volumes": [],
  "placementConstraints": [],
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512",
  "tags": [
    {
      "key": "Environment",
      "value": "production"
    },
    {
      "key": "Application",
      "value": "{{APP_NAME}}"
    }
  ]
}
